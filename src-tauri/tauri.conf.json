{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Sotto",
  "version": "0.1.0",
  "identifier": "app.sotto.daily",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Sotto",
        "width": 460,
        "height": 200,
        "minWidth": 460,
        "minHeight": 200,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "alwaysOnTop": false,
        "skipTaskbar": true,
        "focus": false,
        "visible": false,
        "acceptFirstMouse": false
      }
    ],
    "security": {
      "csp": null
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png"
    ],
    "macOS": {
      "minimumSystemVersion": "11.0"
    }
  }
}
